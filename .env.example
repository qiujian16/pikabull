# ── Provider selection ─────────────────────────────────────────────────────────
# Options: anthropic | openai | ollama | minimax
LLM_PROVIDER=anthropic

# ── Anthropic (Claude) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Ollama / Hermes (or any OpenAI-compatible local endpoint) ──────────────────
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=hermes3
# OLLAMA_API_KEY=ollama          # Ollama ignores this but openai SDK requires it

# ── MiniMax ────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=minimax
# MINIMAX_API_KEY=...
# MINIMAX_MODEL=MiniMax-M2.7-highspeed  # or MiniMax-M2.7, MiniMax-Text-01, MiniMax-M2
# MINIMAX_BASE_URL=https://api.minimax.chat/v1  # use api.minimax.io/v1 for global accounts
